# ─── Facebook Pages ───────────────────────────────────────────
PAGE_1_ID=your_crime_page_id
PAGE_1_TOKEN=your_crime_page_access_token
PAGE_1_NICHE=crime

PAGE_2_ID=your_finance_page_id
PAGE_2_TOKEN=your_finance_page_access_token
PAGE_2_NICHE=finance

PAGE_3_ID=your_weirdnews_page_id
PAGE_3_TOKEN=your_weirdnews_page_access_token
PAGE_3_NICHE=weird

# ─── AI Caption Generation ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Canva API ───────────────────────────────────────────────
CANVA_API_KEY=your_canva_api_key
CANVA_TEMPLATE_CRIME=DAxxxxxxx
CANVA_TEMPLATE_FINANCE=DAxxxxxxx
CANVA_TEMPLATE_WEIRD=DAxxxxxxx

# ─── Timezone ────────────────────────────────────────────────
POST_TIMEZONE=America/New_York
PORT=8000

# ─── AI Providers ─────────────────────────────────────────────
# Gemini is FREE (1500 req/day) — get key at aistudio.google.com
# Anthropic is fallback only — only needed if Gemini is down
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=sk-ant-optional-fallback-key

# ─── Optional: Vercel AI Gateway URL ─────────────────────────
# If you set up a Vercel proxy (see README), put the URL here
# Leave blank to call Gemini/Anthropic directly (recommended)
VERCEL_AI_PROXY_URL=
